# Benedict College MIS API - Environment Variables Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
NODE_ENV=production
PORT=3000

# =============================================================================
# DATABASE CONFIGURATION (MySQL)
# =============================================================================
# Local Development (default values)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=bc_mis

# Production Database (Railway/DigitalOcean/etc.)
# DB_HOST=your-production-db-host.com
# DB_PORT=3306
# DB_USERNAME=your-production-username
# DB_PASSWORD=your-production-password
# DB_DATABASE=bc_mis_prod

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Session Configuration
SESSION_SECRET=your-session-secret-change-this-in-production

# =============================================================================
# CORS & FRONTEND CONFIGURATION
# =============================================================================
# Frontend URL (where your React app is hosted)
FRONTEND_URL=http://localhost:5173

# Allowed Origins (comma-separated list)
# For development: http://localhost:5173,http://localhost:3000
# For production: https://your-frontend-domain.com,https://your-api-domain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# =============================================================================
# FILE STORAGE & UPLOADS
# =============================================================================
# Blob Storage Token (for file uploads)
BLOB_STORAGE_TOKEN=your-blob-storage-token-here

# Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads

# =============================================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=noreply@bc-mis.com

# =============================================================================
# LOGGING & MONITORING
# =============================================================================
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# DEVELOPMENT ONLY
# =============================================================================
# Set to true to enable TypeORM synchronization (NEVER use in production)
DB_SYNCHRONIZE=false
DB_LOGGING=false

# =============================================================================
# PRODUCTION DEPLOYMENT NOTES
# =============================================================================
# 1. Generate strong, unique secrets for JWT_SECRET and JWT_REFRESH_SECRET
# 2. Use a secure database password (not the default letmein25)
# 3. Set FRONTEND_URL to your actual frontend domain
# 4. Update ALLOWED_ORIGINS with your production domains
# 5. Configure proper SMTP settings for email functionality
# 6. Never set DB_SYNCHRONIZE=true in production
# 7. Set LOG_LEVEL=warn or error in production for better performance