{
  "name": "bc-mis-api",
  "version": "1.0.1",
  "type": "commonjs",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "npx ts-node server.ts",
    "dev:watch": "npx nodemon server.ts",
    "prod": "npm run build && npm start",
    "railway:build": "npm run build",
    "railway:start": "npm start",
    "health": "curl -f http://localhost:${PORT:-3000}/api/health || exit 1",
    "check:semester": "npx ts-node scripts/check-semester-column.ts",
    "check:scheduled": "npx ts-node scripts/check-scheduled-status.ts",
    "migrate": "npx ts-node scripts/run-migrations-simple.ts",
    "migrate:old": "npx ts-node scripts/run-migrations.ts",
    "migrate:prod": "node dist/scripts/run-migrations.js",
    "fix:requirements": "npx ts-node scripts/fix-document-requirements.ts",
    "import-subjects": "npx ts-node scripts/import-subjects.ts",
    "import-subjects:prod": "node dist/scripts/import-subjects.js",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'Linting not configured'",
    "test": "echo 'Tests not configured'",
    "extract-ebooks": "npx ts-node scripts/extract-ebook-metadata.ts --path ../ebooks",
    "extract-ebooks:dry-run": "npx ts-node scripts/extract-ebook-metadata.ts --path ../ebooks --dry-run",
    "clean-books": "npx ts-node scripts/clean-books-table.ts",
    "backup-books": "npx ts-node scripts/backup-books.ts",
    "restore-books": "npx ts-node scripts/restore-books.ts",
    "restore-books:list": "npx ts-node scripts/restore-books.ts --list",
    "restore-books:dry-run": "npx ts-node scripts/restore-books.ts --dry-run",
    "import-users": "npx ts-node scripts/import-users.ts",
    "seed-missing-requirements": "npx ts-node scripts/seed-missing-requirements.ts",
    "test:sat": "npx ts-node scripts/test-payment-flow.ts",
    "test:enrollment": "npx ts-node scripts/test-enrollment-flow.ts",
    "test:registrar": "npx ts-node scripts/test-registrar-flow.ts",
    "test:teacher": "npx ts-node scripts/test-teacher-flow.ts",
    "test:librarian": "npx ts-node scripts/test-librarian-flow.ts",
    "test:scheduling": "npx ts-node scripts/test-scheduling-backend.ts",
    "update:requirements": "npx ts-node scripts/update-document-requirements.ts",
    "fix:student-docs": "npx ts-node scripts/fix-student-document-requirements.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.940.0",
    "@aws-sdk/s3-request-presigner": "^3.940.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@vercel/blob": "^0.23.4",
    "@vercel/node": "^3.0.0",
    "axios": "^1.13.5",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^2.4.3",
    "chalk": "^4.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cli-progress": "^3.12.0",
    "commander": "^11.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "epub-parser": "^0.2.5",
    "express": "^4.18.2",
    "handlebars": "^4.7.8",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.0.2",
    "mysql2": "^3.14.3",
    "nodemailer": "^6.9.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdf-parse": "^1.1.1",
    "puppeteer": "^22.0.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "speakeasy": "^2.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20",
    "uuid": "^13.0.0",
    "yauzl": "^2.10.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cli-progress": "^3.11.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.14",
    "@types/passport": "^1.0.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pdf-parse": "^1.1.4",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "nodemon": "^3.0.0",
    "openapi-types": "^12.1.3",
    "ts-node": "^10.9.0",
    "typescript": "~5.8.3"
  },
  "keywords": [
    "express",
    "typescript",
    "mysql",
    "typeorm",
    "school-management",
    "mis"
  ],
  "author": "Benedict College MIS Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/bc-mis.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/bc-mis/issues"
  },
  "homepage": "https://github.com/your-org/bc-mis#readme"
}
