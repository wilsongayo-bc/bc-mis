{
  "name": "bc-mis",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "client:dev": "vite",
    "build": "npm run build:client && npm run build:api",
    "build:client": "tsc -b && vite build",
    "build:api": "tsc --project api/tsconfig.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "tsc --noEmit",
    "type-check": "npm run check",
    "server:dev": "nodemon",
    "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
    "init-users": "tsx api/scripts/init-users.ts",
    "init-data": "tsx api/scripts/init-default-data.ts",
    "seed": "node api/dist/scripts/seed-data.js",
    "seed:dev": "tsx api/scripts/seed-data.ts",
    "ensure-tables": "tsx api/scripts/ensure-tables.ts",
    "db:init": "npm run ensure-tables",
    "migrate-data": "tsx api/scripts/migrate-data.ts",
    "migrate:local-to-remote": "tsx api/scripts/migrate-data.ts local-to-remote",
    "migrate:prod": "node api/dist/scripts/run-migrations.js",
    "migrate:remote-to-local": "tsx api/scripts/migrate-data.ts remote-to-local",
    "configure-cors": "tsx api/scripts/configure-r2-cors.ts",
    "configure-cors:prod": "node api/dist/scripts/configure-r2-cors.js",
    "migrate:dry-run": "tsx api/scripts/migrate-data.ts local-to-remote --dry-run --verbose",
    "sync-schedules": "tsx scripts/smart_dump_schedules.ts",
    "extract-ebooks": "tsx api/scripts/extract-ebook-metadata.ts",
    "extract-ebooks:dry-run": "tsx api/scripts/extract-ebook-metadata.ts --dry-run --verbose",
    "vercel-build": "npm run build:client",
    "add-full-reqs": "tsx api/scripts/add-full-registration-requirements.ts",
    "add-full-reqs:prod": "node api/dist/scripts/add-full-registration-requirements.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.940.0",
    "@aws-sdk/s3-request-presigner": "^3.940.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/typeorm": "^11.0.3",
    "@reduxjs/toolkit": "^2.0.0",
    "@types/multer": "^2.0.0",
    "@types/pg": "^8.15.5",
    "@vercel/blob": "^2.0.0",
    "axios": "^1.11.0",
    "chalk": "^5.3.0",
    "chart.js": "^4.5.0",
    "chartjs-adapter-date-fns": "^3.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cli-progress": "^3.12.0",
    "clsx": "^2.1.1",
    "commander": "^14.0.1",
    "cors": "^2.8.5",
    "date-fns": "^4.4.0",
    "dotenv": "^17.2.1",
    "exceljs": "^3.4.0",
    "express": "^4.21.2",
    "file-saver": "^2.0.5",
    "handlebars": "^4.7.8",
    "jsonwebtoken": "^9.0.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.511.0",
    "multer": "^2.0.2",
    "mysql2": "^3.15.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^9.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.16.3",
    "puppeteer": "^24.24.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.1",
    "react-redux": "^9.0.0",
    "react-router-dom": "^7.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
    "sonner": "^2.0.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tailwind-merge": "^3.0.2",
    "typeorm": "^0.3.26",
    "uuid": "^14.0.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/file-saver": "^2.0.7",
    "@types/handlebars": "^4.0.40",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.15.30",
    "@types/nodemailer": "^6.4.0",
    "@types/passport": "^1.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/passport-local": "^1.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.0",
    "@vercel/node": "^4.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-dev-locator": "^1.0.0",
    "baseline-browser-mapping": "^2.10.43",
    "bcrypt": "^6.0.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "vite-plugin-trae-solo-badge": "^1.0.0",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
