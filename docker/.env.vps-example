# VPS Deployment Environment Configuration
# Copy this file to .env.production and update with your actual values

# Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=bc_user
DB_PASSWORD=letmein25
DB_DATABASE=bc_mis

# JWT Configuration
JWT_SECRET=bf81e646b781a2cd6f266762bae13b430b06b6de341803117799acecbec6b2d8c8f502fe471777410a8018aaa107f6c6b4cb44d9e2f1f2ac6aaf3e53e545cec7
JWT_EXPIRES_IN=24h

# Server Configuration
NODE_ENV=production
PORT=3000

# Domain Configuration (replace with your actual domain)
SERVER_NAME=api.benedictcollege.com

# Optional: Vercel Blob Storage for file uploads
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token-here

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Limits
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads

# Logging
LOG_LEVEL=info
LOG_FILE=/var/log/bc-mis/api.log