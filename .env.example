# Database Configuration
DB_PORT=3306

# Local Development Database
DB_HOST=localhost
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=bc_mis

# Auto-run migrations on server start (set to 'false' to disable)
AUTO_MIGRATE=true

# Production Database (replace with your actual values)
DB_HOST=your-database-host
DB_USERNAME=your-database-username
DB_PASSWORD=your-database-password
DB_DATABASE=your-database-name

# JWT Configuration (generate a secure random string)
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES_IN=24h

# Email Configuration (for notifications and 2FA)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@domain.com
EMAIL_PASS=your-email-password

# 2FA Email Configuration (uses same SMTP settings as above)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@domain.com
MAIL_PASSWORD=your-email-password
MAIL_FROM=Benedict College MIS <noreply@benedictcollege.com>

# 2FA SMS Configuration (Optional - choose one provider)
# Leave SMS_PROVIDER empty to disable SMS (codes will be logged to console in development)
SMS_PROVIDER=

# Option 1: Twilio (Recommended for SMS)
# Sign up at: https://www.twilio.com
# Get credentials from: https://console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Option 2: AWS SNS (Alternative for SMS)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# File Upload Configuration
FILE_UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Vercel Blob Storage Configuration
# Get your token from: https://vercel.com/dashboard → Storage → Blob
# Token format: vercel_blob_rw_XXXXXXXXXX
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your_token_here

# Vercel OIDC Token (for Vercel deployment authentication)
# Get from: https://vercel.com/account/tokens
VERCEL_OIDC_TOKEN=your_vercel_oidc_token_here

# Application Configuration
PORT=3001
NODE_ENV=development

# Seed Data Configuration (for initial data setup)
SEED_KEY=your-seed-key-here